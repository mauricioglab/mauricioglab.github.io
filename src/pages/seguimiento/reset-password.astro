---
import BaseTailwind from '../../layouts/BaseTailwind.astro';

export const prerender = true;
---

<BaseTailwind
  title="Restablecer contraseña — Seguimiento"
  description="Restablecer contraseña del Panel de Seguimiento"
  lang="es"
  layoutType="tool"
  showHeader={true}
  showFooter={false}
>
  <div class="min-h-[60vh] flex items-center justify-center px-4" x-data="resetPassword()">
    <div class="bg-white rounded-xl p-6 w-full max-w-sm border border-gray-300 shadow-lg">
      <!-- Error: no token -->
      <template x-if="!hasToken">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto text-red-500 mb-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
          <h2 class="text-lg font-bold text-gray-900 mb-2">Enlace inválido</h2>
          <p class="text-sm text-gray-500 mb-4">Este enlace no es válido o ya expiró. Solicitá uno nuevo desde el panel de seguimiento.</p>
          <a href="/seguimiento/" class="inline-block px-4 py-2 bg-indigo-700 text-white text-sm font-bold rounded-lg hover:bg-indigo-800">Volver al panel</a>
        </div>
      </template>
      <!-- Reset form -->
      <template x-if="hasToken && !success">
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-4">Nueva contraseña</h2>
          <form @submit.prevent="resetPassword()">
            <div class="mb-3">
              <label class="block text-xs font-bold text-gray-700 mb-1">Nueva contraseña</label>
              <input
                x-model="newPassword"
                type="password"
                minlength="6"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600"
                placeholder="Mínimo 6 caracteres"
                required
              >
            </div>
            <div class="mb-4">
              <label class="block text-xs font-bold text-gray-700 mb-1">Confirmar contraseña</label>
              <input
                x-model="confirmPassword"
                type="password"
                minlength="6"
                class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600"
                required
              >
            </div>
            <p x-show="error" class="text-xs text-red-600 mb-3 font-bold" x-text="error"></p>
            <button
              type="submit"
              class="w-full py-2 bg-indigo-700 text-white text-sm font-bold rounded-lg hover:bg-indigo-800"
              :disabled="loading"
            >
              <span x-text="loading ? '...' : 'Guardar contraseña'"></span>
            </button>
          </form>
        </div>
      </template>
      <!-- Success -->
      <template x-if="success">
        <div class="text-center">
          <svg class="w-12 h-12 mx-auto text-green-500 mb-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <h2 class="text-lg font-bold text-gray-900 mb-2">Contraseña actualizada</h2>
          <p class="text-sm text-gray-500 mb-4">Tu contraseña fue restablecida correctamente. Ya podés ingresar al panel con tu nueva contraseña.</p>
          <a href="/seguimiento/" class="inline-block px-4 py-2 bg-indigo-700 text-white text-sm font-bold rounded-lg hover:bg-indigo-800">Ir al panel</a>
        </div>
      </template>
    </div>
  </div>
</BaseTailwind>

<script>
  import Alpine from 'alpinejs';
  import { supabase } from '../../lib/supabase';

  window.Alpine = Alpine;

  Alpine.data('resetPassword', () => ({
    hasToken: false,
    accessToken: '',
    newPassword: '',
    confirmPassword: '',
    loading: false,
    error: '',
    success: false,

    init() {
      const hash = window.location.hash;
      if (hash) {
        const params = new URLSearchParams(hash.substring(1));
        const type = params.get('type');
        const token = params.get('access_token');
        if (type === 'recovery' && token) {
          this.hasToken = true;
          this.accessToken = token;
          supabase.auth.setSession({
            access_token: token,
            refresh_token: params.get('refresh_token') || ''
          });
        }
      }
    },

    async resetPassword() {
      this.error = '';
      if (this.newPassword.length < 6) {
        this.error = 'La contraseña debe tener al menos 6 caracteres';
        return;
      }
      if (this.newPassword !== this.confirmPassword) {
        this.error = 'Las contraseñas no coinciden';
        return;
      }
      this.loading = true;
      try {
        const { error } = await supabase.auth.updateUser({ password: this.newPassword });
        if (error) throw error;
        this.success = true;
      } catch (e) {
        this.error = e.message || 'Error al actualizar la contraseña';
      } finally {
        this.loading = false;
      }
    }
  }));

  Alpine.start();
</script>