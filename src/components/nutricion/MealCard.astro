---
const { meal } = Astro.props;
---
<div class="meal-card bg-white border border-gray-200 rounded-xl mb-4 overflow-hidden shadow-sm transition-all duration-200 cursor-pointer active:scale-95" data-id={meal.id}>
  <div class="p-4">
    <div class="flex justify-between items-start mb-2">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block bg-blue-50 text-blue-600 text-[11px] font-semibold px-2 py-0.5 rounded-md">{meal.category}</span>
          {meal.lowCarb && (
            <span class="inline-flex items-center gap-1 bg-green-50 border border-green-200 text-green-700 text-[11px] font-semibold px-2 py-0.5 rounded-md">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
              Low Carb
            </span>
          )}
        </div>
        <h3 class="text-lg font-bold text-gray-800 leading-tight mb-1">{meal.name}</h3>
        <p class="text-sm text-gray-500 missing-info"></p>
      </div>
    </div>

    <div class="frequency-selector hidden mt-3 pt-3 border-t border-gray-100">
      <p class="text-xs font-bold text-gray-600 mb-2">¿Cuántas veces por semana?</p>
      <div class="flex gap-1.5 flex-wrap">
        <button class="freq-btn w-8 h-8 flex items-center justify-center rounded-md border border-red-200 text-sm font-medium text-red-400 transition-colors hover:bg-red-50" data-meal={meal.id} data-val={0}>✕</button>
        {[1, 2, 3, 4, 5, 6, 7].map(num => (
          <button class="freq-btn w-8 h-8 flex items-center justify-center rounded-md border border-gray-300 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-50" data-meal={meal.id} data-val={num}>{num}</button>
        ))}
      </div>
    </div>
  </div>
</div>
