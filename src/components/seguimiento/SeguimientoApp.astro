  function calcPct(scores) {
    if (!scores) return null;
    const vals = [scores.FN, scores.DEV, scores.SM].filter(v => v !== undefined && v !== null && v !== "");
    if (!vals.length) return null;
    return vals.reduce((a, b) => a + Number(b), 0) / (vals.length * 10);
  }

  function calcNota(pct) {
    return pct !== null ? (pct * 10).toFixed(1) : "—";
  }

  function notaColor(nota) {
    if (nota === "—") return "text-slate-400";
    const n = parseFloat(nota);
    if (n >= 8) return "text-green-500";
    if (n >= 6) return "text-amber-500";
    return "text-red-500";
  }

  function notaBadgeClass(nota) {
    if (nota === "—") return "bg-slate-100 text-slate-400";
    const n = parseFloat(nota);
    if (n >= 8) return "bg-green-50 text-green-600";
    if (n >= 6) return "bg-amber-50 text-amber-600";
    return "bg-red-50 text-red-600";
  }

  function pctColor(pct) {
    if (pct >= 80) return "bg-green-500";
    if (pct >= 60) return "bg-amber-500";
    return "bg-red-500";
  }

  function asistBtnClass(val) {
    const map = {
      Presente: "border-green-500 text-green-500 bg-green-50",
      Ausente: "border-red-500 text-red-500 bg-red-50",
      Justificado: "border-amber-500 text-amber-500 bg-amber-50"
    };
    return map[val] || "";
  }

  function asistTextClass(val) {
    const map = {
      Presente: "text-green-600",
      Ausente: "text-red-600",
      Justificado: "text-amber-600"
    };
    return map[val] || "text-slate-400";
  }

  function dimColor(dim) {
    const map = { FN: "text-indigo-500", DEV: "text-sky-500", SM: "text-amber-500" };
    return map[dim] || "";
  }

  function dimBarColor(dim) {
    const map = { FN: "bg-indigo-500", DEV: "bg-sky-500", SM: "bg-amber-500" };
    return map[dim] || "";
