---
// Componente principal de seguimiento - Alpine.js + Supabase
---

<div 
  x-data="seguimientoApp()" 
  x-init="init()" 
  class="min-h-screen bg-gray-100 font-sans"
  x-cloak
>
  <!-- Header -->
  <header class="bg-white border-b border-gray-300 sticky top-0 z-30 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 py-3">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-lg font-bold text-gray-900">Práctica Profesionalizante</h1>
          <p class="text-xs text-gray-600" x-text="`${gruposFiltrados.length} grupos activos`"></p>
        </div>
        <div class="flex items-center gap-3">
          <button 
            x-show="canEdit && (view === 'resumen' || view === 'encuentros' || view === 'stats')"
            @click="openAddGrupoModal()"
            class="w-8 h-8 flex items-center justify-center rounded-lg bg-indigo-600 text-white text-sm font-bold hover:bg-indigo-700 transition"
            title="Agregar grupo"
          >
            +
          </button>
          <template x-if="!user">
            <button 
              @click="showLogin = true"
              class="px-3 py-1.5 bg-indigo-700 text-white text-sm font-medium rounded-lg hover:bg-indigo-800 transition"
            >
              Ingresar
            </button>
          </template>
          <template x-if="user">
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-700 font-medium" x-text="user.email"></span>
              <button 
                @click="logout()"
                class="px-3 py-1.5 text-xs text-red-700 hover:bg-red-50 rounded-lg transition font-medium"
              >
                Salir
              </button>
            </div>
          </template>
        </div>
      </div>
      
      <!-- Tabs de práctica -->
      <nav class="flex gap-1 mt-2 mb-1 overflow-x-auto">
        <template x-for="p in practicas" :key="p.id">
          <button 
            @click="practicaFilter = p.id"
            class="px-3 py-1.5 text-xs font-bold rounded-md transition whitespace-nowrap"
            :class="practicaFilter === p.id ? 'bg-indigo-700 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'"
            x-text="p.label"
          ></button>
        </template>
      </nav>
      
      <!-- Tabs de navegación -->
      <nav class="flex gap-0 mt-2 -mb-px" x-show="view === 'resumen' || view === 'encuentros' || view === 'stats'">
        <button 
          @click="view = 'resumen'"
          class="flex-1 py-2 text-sm font-bold border-b-2 transition"
          :class="view === 'resumen' ? 'border-indigo-700 text-indigo-700' : 'border-transparent text-gray-600 hover:text-gray-800'"
        >
          Resumen
        </button>
        <button 
          x-show="canEdit"
          @click="view = 'encuentros'"
          class="flex-1 py-2 text-sm font-bold border-b-2 transition"
          :class="view === 'encuentros' ? 'border-indigo-700 text-indigo-700' : 'border-transparent text-gray-600 hover:text-gray-800'"
        >
          Encuentros
        </button>
        <button 
          x-show="canEdit"
          @click="view = 'stats'"
          class="flex-1 py-2 text-sm font-bold border-b-2 transition"
          :class="view === 'stats' ? 'border-indigo-700 text-indigo-700' : 'border-transparent text-gray-600 hover:text-gray-800'"
        >
          Stats
        </button>
      </nav>
    </div>
  </header>

  <!-- Main Content -->
  <main class="max-w-6xl mx-auto px-4 py-4">
    
    <!-- Loading -->
    <div x-show="loadingData" class="text-center py-12">
      <div class="inline-block w-8 h-8 border-2 border-indigo-700 border-t-transparent rounded-full animate-spin"></div>
      <p class="text-sm text-gray-600 mt-2 font-medium">Cargando datos...</p>
    </div>

    <!-- VISTA RESUMEN -->
    <div x-show="view === 'resumen' && !loadingData" x-transition>
      <div class="mb-4">
        <input 
          x-model="filtro"
          placeholder="Buscar grupo o proyecto..."
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 bg-white"
        >
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-gray-600 text-left">
              <th class="px-2 py-2 font-bold">Grupo</th>
              <th class="px-2 py-2 font-bold">Comisión</th>
              <template x-for="enc in encuentrosMeta" :key="enc.id">
                <th class="px-1 py-2 font-bold text-center w-12">
                  <button @click="selectEncuentro(enc.id)" class="text-indigo-700 font-bold hover:underline" x-text="enc.id"></button>
                </th>
              </template>
              <th class="px-2 py-2 font-bold text-center">Prom.</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="grupo in gruposFiltrados" :key="grupo.id">
              <tr 
                @click="selectGrupo(grupo.id)"
                class="bg-white cursor-pointer hover:bg-gray-50 transition shadow-sm border-b border-gray-100"
              >
                <td class="px-2 py-2.5 rounded-l-lg">
                  <span class="text-gray-500 text-xs mr-1 font-bold" x-text="`G${grupo.id}`"></span>
                  <span class="font-bold text-gray-900" x-text="grupo.proyecto"></span>
                </td>
                <td class="px-2 py-2.5 text-gray-700 font-medium" x-text="grupo.comision || '—'"></td>
                <template x-for="enc in encuentrosMeta" :key="enc.id">
                  <td class="px-1 py-2.5 text-center">
                    <span 
                      class="inline-flex items-center justify-center min-w-[2.5rem] h-6 rounded-md text-xs font-bold"
                      :class="notaBadgeClass(calcNota(calcPct(data[enc.id]?.[grupo.id])))"
                      x-text="calcNota(calcPct(data[enc.id]?.[grupo.id]))"
                    ></span>
                  </td>
                </template>
                <td class="px-2 py-2.5 text-center rounded-r-lg">
                  <span 
                    class="inline-flex items-center justify-center min-w-[3rem] h-8 rounded-lg text-sm font-bold"
                    :class="notaBadgeClass(calcNota(promedioEncuentros(grupo.id)))"
                    x-text="calcNota(promedioEncuentros(grupo.id))"
                  ></span>
                </td>
              </tr>
            </template>
          </tbody>
        </table>
      </div>
    </div>

    <!-- VISTA ENCUENTROS LISTA -->
    <div x-show="view === 'encuentros' && !loadingData" x-transition>
      <h2 class="text-base font-bold text-gray-900 mb-3">Encuentros</h2>
      <div class="space-y-2">
        <template x-for="enc in encuentrosMeta" :key="enc.id">
          <button 
            @click="selectEncuentro(enc.id)"
            class="w-full bg-white rounded-xl p-4 text-left hover:shadow-md transition flex items-center gap-3 border border-gray-200"
          >
            <div class="w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center font-bold text-indigo-700 text-sm" x-text="enc.id"></div>
            <div class="flex-1">
              <div class="font-bold text-sm text-gray-900" x-text="enc.nombre"></div>
              <div class="text-xs text-gray-500 italic" x-text="enc.pregunta"></div>
            </div>
            <div class="text-xs text-gray-500 font-bold" x-text="`${countGruposEvaluados(enc.id)} grupos`"></div>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </template>
      </div>
    </div>

    <!-- VISTA ESTADISTICAS -->
    <div x-show="view === 'stats' && !loadingData" x-transition x-effect="if(view==='stats') renderStats()">
      <h2 class="text-base font-bold text-gray-900 mb-3">Estadísticas Avanzadas</h2>
      
      <!-- Filtros -->
      <div class="bg-white rounded-xl p-3 mb-3 border border-gray-200 shadow-sm flex flex-wrap gap-2 items-center">
        <label class="text-xs font-bold text-gray-700">Comisión:</label>
        <select x-model="statsComisionFilter" class="px-2 py-1 text-xs border border-gray-300 rounded bg-white" @change="renderStats()">
          <option value="">Todas</option>
          <template x-for="c in comisiones" :key="c.id">
            <option :value="c.id" x-text="c.nombre"></option>
          </template>
        </select>
        
        <label class="text-xs font-bold text-gray-700 ml-2">Práctica:</label>
        <select x-model="statsPracticaFilter" class="px-2 py-1 text-xs border border-gray-300 rounded bg-white" @change="renderStats()">
          <option value="">Todas</option>
          <option value="P1">P1</option>
          <option value="P2">P2</option>
          <option value="P3">P3</option>
          <option value="TutoriasPost">Tutorías Post</option>
        </select>
        
        <label class="text-xs font-bold text-gray-700 ml-2">Encuentro:</label>
        <select x-model="statsEncuentroFilter" class="px-2 py-1 text-xs border border-gray-300 rounded bg-white" @change="renderStats()">
          <option value="">Todos</option>
          <template x-for="enc in encuentrosMeta" :key="enc.id">
            <option :value="enc.id" x-text="enc.id"></option>
          </template>
        </select>
      </div>
      
      <!-- Métricas resumen -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3">
        <div class="bg-white rounded-xl p-3 border border-gray-200 shadow-sm text-center">
          <div class="text-xs text-gray-500 font-bold uppercase">Grupos evaluados</div>
          <div class="text-2xl font-extrabold text-gray-900" x-text="statsResumen.evaluados"></div>
        </div>
        <div class="bg-white rounded-xl p-3 border border-green-200 shadow-sm text-center">
          <div class="text-xs text-green-700 font-bold uppercase">Habilitados</div>
          <div class="text-2xl font-extrabold text-green-700" x-text="statsResumen.habilitados"></div>
        </div>
        <div class="bg-white rounded-xl p-3 border border-amber-200 shadow-sm text-center">
          <div class="text-xs text-amber-700 font-bold uppercase">Condicionales</div>
          <div class="text-2xl font-extrabold text-amber-700" x-text="statsResumen.condicionales"></div>
        </div>
        <div class="bg-white rounded-xl p-3 border border-red-200 shadow-sm text-center">
          <div class="text-xs text-red-700 font-bold uppercase">Críticos</div>
          <div class="text-2xl font-extrabold text-red-700" x-text="statsResumen.criticos"></div>
        </div>
      </div>
      
      <!-- Gráficos Plotly -->
      <div class="bg-white rounded-xl p-4 mb-3 border border-gray-200 shadow-sm">
        <h3 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Evolución Temporal por Dimensión</h3>
        <div id="plot-evolucion" class="w-full" style="min-height: 320px;"></div>
      </div>
      
      <div class="grid md:grid-cols-2 gap-3 mb-3">
        <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm">
          <h3 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Primera Nota vs Modificación</h3>
          <div id="plot-scatter" class="w-full" style="min-height: 320px;"></div>
        </div>
        
        <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm">
          <h3 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Capacidad de Mejora</h3>
          <div id="plot-mejora" class="w-full" style="min-height: 320px;"></div>
        </div>
      </div>
      
      <div class="grid md:grid-cols-2 gap-3 mb-3">
        <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm">
          <h3 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Distribución de Notas</h3>
          <div id="plot-histogram" class="w-full" style="min-height: 320px;"></div>
        </div>
        
        <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm">
          <h3 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Estado de Grupos</h3>
          <div id="plot-estados" class="w-full" style="min-height: 320px;"></div>
        </div>
      </div>
      
      <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm mb-3">
        <h3 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-3">Heatmap Comisiones × Encuentros</h3>
        <div id="plot-heatmap" class="w-full" style="min-height: 360px;"></div>
      </div>
      
      <!-- Estadísticas de Ausencias -->
      <div class="bg-white rounded-xl p-4 border border-gray-200 shadow-sm">
        <h3 class="text-sm font-bold text-gray-900 uppercase tracking-wide mb-4">📊 Estadísticas de Ausencias</h3>
        
        <!-- Grupos con más ausentes -->
        <div class="mb-6">
          <h4 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Grupos con más ausencias</h4>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50">
                  <th class="px-3 py-2 text-left text-xs font-bold text-gray-700">Grupo</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-red-700">Ausentes</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-amber-700">Justificados</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-gray-700">Total inasistencias</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-gray-700">%</th>
                </tr>
              </thead>
              <tbody>
                <template x-for="item in getAusenciasPorGrupo()" :key="item.grupo">
                  <tr class="border-b border-gray-100 hover:bg-gray-50">
                    <td class="px-3 py-2 font-medium text-gray-900" x-text="item.grupo"></td>
                    <td class="px-3 py-2 text-center text-red-600 font-bold" x-text="item.ausentes"></td>
                    <td class="px-3 py-2 text-center text-amber-600 font-bold" x-text="item.justificados"></td>
                    <td class="px-3 py-2 text-center font-bold text-gray-900" x-text="item.totalInasistencias"></td>
                    <td class="px-3 py-2 text-center text-gray-600" x-text="item.porcentaje + '%'"></td>
                  </tr>
                </template>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- Ausentes por encuentro -->
        <div class="mb-6">
          <h4 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Ausencias por encuentro</h4>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50">
                  <th class="px-3 py-2 text-left text-xs font-bold text-gray-700">Encuentro</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-red-700">Ausentes</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-amber-700">Justificados</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-gray-700">Total inasistencias</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-gray-700">%</th>
                </tr>
              </thead>
              <tbody>
                <template x-for="item in getAusenciasPorEncuentro()" :key="item.encuentro">
                  <tr class="border-b border-gray-100 hover:bg-gray-50">
                    <td class="px-3 py-2 font-medium text-gray-900" x-text="item.encuentro + ' — ' + item.nombre.split('—')[1]?.trim()"></td>
                    <td class="px-3 py-2 text-center text-red-600 font-bold" x-text="item.ausentes"></td>
                    <td class="px-3 py-2 text-center text-amber-600 font-bold" x-text="item.justificados"></td>
                    <td class="px-3 py-2 text-center font-bold text-gray-900" x-text="item.totalInasistencias"></td>
                    <td class="px-3 py-2 text-center text-gray-600" x-text="item.porcentaje + '%'"></td>
                  </tr>
                </template>
              </tbody>
            </table>
          </div>
        </div>
        
        <!-- Alumnos con más ausentes -->
        <div>
          <h4 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Alumnos con más ausencias</h4>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-gray-50">
                  <th class="px-3 py-2 text-left text-xs font-bold text-gray-700">Alumno</th>
                  <th class="px-3 py-2 text-left text-xs font-bold text-gray-700">Grupo</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-red-700">Ausentes</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-amber-700">Justificados</th>
                  <th class="px-3 py-2 text-center text-xs font-bold text-gray-700">Total inasistencias</th>
                </tr>
              </thead>
              <tbody>
                <template x-for="item in getAusenciasPorAlumno()" :key="item.nombre">
                  <tr class="border-b border-gray-100 hover:bg-gray-50">
                    <td class="px-3 py-2 font-medium text-gray-900" x-text="item.nombre"></td>
                    <td class="px-3 py-2 text-gray-600 text-xs" x-text="item.grupo"></td>
                    <td class="px-3 py-2 text-center text-red-600 font-bold" x-text="item.ausentes"></td>
                    <td class="px-3 py-2 text-center text-amber-600 font-bold" x-text="item.justificados"></td>
                    <td class="px-3 py-2 text-center font-bold text-gray-900" x-text="item.ausentes + item.justificados"></td>
                  </tr>
                </template>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- VISTA GRUPO DETALLE -->
    <div x-show="view === 'grupo' && selectedGrupo && !loadingData" x-transition>
      <div class="flex items-center gap-3 mb-4">
        <button @click="view = 'resumen'" class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-600 hover:text-gray-900 hover:bg-gray-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="flex-1">
          <h2 class="text-lg font-extrabold text-gray-900" x-text="`G${grupoActual?.id} · ${grupoActual?.proyecto}`"></h2>
          <p class="text-xs text-gray-600 font-medium" x-text="`Grupo ${grupoActual?.id} ${grupoActual?.comision ? '· ' + grupoActual.comision : ''} ${grupoActual?.practica ? '· ' + grupoActual.practica : ''}`"></p>
        </div>
        <div 
          class="px-3 py-1 rounded-full text-sm font-extrabold"
          :class="notaBadgeClass(calcNota(promedioEncuentros(grupoActual?.id)))"
          x-text="'Prom: ' + calcNota(promedioEncuentros(grupoActual?.id))"
        ></div>
        <div class="flex items-center gap-2">
          <button 
            x-show="canEdit"
            @click="openEditGrupoModal()"
            class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition"
            title="Editar grupo"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button 
            x-show="canEdit"
            @click="confirmDeleteGrupo()"
            class="w-9 h-9 flex items-center justify-center rounded-lg border border-red-200 bg-red-50 text-red-600 hover:bg-red-100 transition"
            title="Eliminar grupo"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
          </button>
          <button 
            x-show="canEdit"
            @click="guardar()"
            class="px-3 py-2 text-white text-sm font-bold rounded-lg hover:bg-indigo-800 transition flex items-center gap-2"
            :class="saved ? 'bg-green-600 hover:bg-green-700' : 'bg-indigo-700 hover:bg-indigo-800'"
          >
            <span x-text="saved ? '¡Guardado!' : 'Guardar'"></span>
          </button>
        </div>
      </div>

      <!-- Tabs de encuentros -->
      <div class="flex gap-1.5 mb-4 overflow-x-auto pb-1">
        <template x-for="enc in encuentrosMeta" :key="enc.id">
          <button 
            @click="activeE = enc.id"
            class="flex-shrink-0 px-3 py-1.5 rounded-lg border-2 text-xs font-bold transition"
            :class="activeE === enc.id ? 'border-indigo-700 bg-indigo-700 text-white' : 'border-gray-300 bg-white text-gray-600'"
          >
            <span x-text="enc.id"></span>
            <span 
              class="block text-center text-[10px] mt-0.5"
              :class="activeE === enc.id ? 'text-white/80' : notaColorClass(calcNota(calcPct(localData[enc.id])))"
              x-text="calcNota(calcPct(localData[enc.id]))"
            ></span>
            <span 
              class="block text-center text-[9px] mt-0.5 opacity-70"
              :class="activeE === enc.id ? 'text-white/60' : 'text-gray-500'"
              x-text="'G:' + calcNota(promedioEncuentros(selectedGrupo))"
            ></span>
          </button>
        </template>
      </div>

      <!-- Encuentro activo -->
      <div class="bg-white rounded-xl p-4 mb-3 border border-gray-200 shadow-sm" x-show="encuentroActual">
        <div class="flex items-center justify-between mb-1">
          <h3 class="font-bold text-sm text-gray-900" x-text="encuentroActual?.nombre"></h3>
          <span 
            class="px-2 py-0.5 rounded-full text-xs font-extrabold"
            :class="notaBadgeClass(calcNota(promedioEncuentros(selectedGrupo)))"
            x-text="'Promedio general: ' + calcNota(promedioEncuentros(selectedGrupo))"
          ></span>
        </div>
        <p class="text-xs text-gray-600 italic mb-4 font-medium" x-text="encuentroActual?.pregunta"></p>

        <!-- Asistencia -->
        <div class="mb-4">
          <h4 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Asistencia</h4>
          <div class="space-y-2">
            <template x-for="int in grupoActual?.integrantes" :key="int.nombre">
              <div class="flex items-center justify-between gap-2 py-1 border-b border-gray-50">
                <div>
                  <span class="text-sm text-gray-900 font-bold" x-text="int.nombre"></span>
                  <span class="text-xs text-gray-600 ml-1 font-medium" x-text="int.rol"></span>
                  <span x-show="int.obs" class="text-xs text-amber-600 ml-1 font-bold" x-text="'('+int.obs+')'"></span>
                </div>
                <div class="flex gap-1" x-show="canEdit">
                  <template x-for="opt in ['Presente (Presencial)','Presente (Virtual)','Ausente','Justificado']" :key="opt">
                    <button 
                      @click="setAsist(int.nombre, localAsist[activeE]?.[int.nombre] === opt ? '' : opt)"
                      class="w-7 h-7 rounded-md border text-xs flex items-center justify-center transition font-bold"
                      :class="localAsist[activeE]?.[int.nombre] === opt ? asistBtnClass(opt) : 'border-gray-300 text-gray-400 bg-white'"
                      x-text="opt === 'Presente (Presencial)' ? 'P' : opt === 'Presente (Virtual)' ? 'V' : opt === 'Ausente' ? '✕' : '−'"
                    ></button>
                  </template>
                </div>
                <span x-show="!canEdit" class="text-xs font-bold" :class="asistTextClass(localAsist[activeE]?.[int.nombre])" x-text="localAsist[activeE]?.[int.nombre] || '—'"></span>
              </div>
            </template>
          </div>
        </div>

        <!-- Dimensiones -->
        <h4 class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Evaluación de Dimensiones</h4>
        <template x-for="[dim, label, color] in [['FN','FN — Análisis Funcional','text-indigo-600'],['DEV','DEV — Técnico','text-sky-600'],['SM','SM/PO — Gestión','text-amber-600']]" :key="dim">
          <div class="mb-3 p-3 rounded-lg bg-gray-50 border border-gray-200">
            <div class="flex items-center justify-between mb-2">
              <span class="font-bold text-sm" :class="color" x-text="label"></span>
              <input
                x-show="canEdit"
                type="number" min="0" :max="((evalMeta[activeE + '_' + selectedGrupo]?.es_modificacion || (data[activeE]?.[selectedGrupo]?.FN || data[activeE]?.[selectedGrupo]?.DEV || data[activeE]?.[selectedGrupo]?.SM)) && !localOverride[activeE]) ? 7 : 10" step="0.5"
                :value="localData[activeE]?.[dim] ?? ''"
                @input="setField(activeE, dim, $event.target.value === '' ? null : Number($event.target.value))"
                class="w-14 px-2 py-1 border border-gray-300 rounded-lg text-sm text-center focus:outline-none focus:ring-2 focus:ring-indigo-600 text-gray-900 font-bold"
              >
              <span x-show="!canEdit" class="font-bold text-sm text-gray-900" x-text="localData[activeE]?.[dim] ?? '—'"></span>
            </div>
            <p class="text-xs text-gray-600 mb-2 font-medium" x-text="criterioActual(dim)"></p>
            <input 
              x-show="canEdit"
              placeholder="Retroalimentación..."
              :value="localData[activeE]?.feedback?.[dim] ?? ''"
              @input="setFb(activeE, dim, $event.target.value)"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-xs focus:outline-none focus:ring-2 focus:ring-indigo-600 text-gray-900"
            >
            <p x-show="!canEdit" class="text-xs text-gray-700 font-medium" x-text="localData[activeE]?.feedback?.[dim] || 'Sin feedback'"></p>
          </div>
        </template>

        <!-- Fechas y override -->
        <div class="mt-3 pt-3 border-t border-gray-200 space-y-2" x-data="{ key: activeE + '_' + selectedGrupo, meta: evalMeta[activeE + '_' + selectedGrupo] || {} }">
          <div x-show="meta.fecha_primera_nota" class="flex items-center justify-between text-xs text-gray-500">
            <span>Primera nota: <span x-text="meta.fecha_primera_nota ? new Date(meta.fecha_primera_nota).toLocaleDateString('es-AR') : '—'"></span></span>
            <span x-show="meta.fecha_modificacion">Modificación: <span x-text="new Date(meta.fecha_modificacion).toLocaleDateString('es-AR')"></span></span>
          </div>
          
          <label 
            x-show="canEdit && (meta.es_modificacion || (data[activeE]?.[selectedGrupo]?.FN || data[activeE]?.[selectedGrupo]?.DEV || data[activeE]?.[selectedGrupo]?.SM))" 
            class="flex items-center gap-2 text-xs font-bold text-gray-700 cursor-pointer"
          >
            <input 
              type="checkbox" 
              x-model="localOverride[activeE]"
              class="w-4 h-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600"
            >
            Override límite de modificación (permite nota >7)
          </label>
        </div>

        <!-- Nota calculada -->
        <div class="flex items-center justify-end gap-2 mt-2">
          <span class="text-sm text-gray-700 font-bold">Nota del encuentro:</span>
          <span 
            class="inline-flex items-center justify-center min-w-[3rem] h-8 rounded-lg text-sm font-bold"
            :class="notaBadgeClass(calcNota(calcPct(localData[activeE])))"
            x-text="calcNota(calcPct(localData[activeE]))"
          ></span>
        </div>
      </div>
    </div>

    <!-- VISTA ENCUENTRO DETALLE -->
    <div x-show="view === 'encuentro' && selectedEnc && !loadingData" x-transition>
      <div class="flex items-center gap-3 mb-4">
        <button @click="view = 'resumen'" class="w-9 h-9 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-600 hover:text-gray-900 hover:bg-gray-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div>
          <h2 class="text-lg font-extrabold text-gray-900" x-text="encuentroSeleccionado?.nombre"></h2>
          <p class="text-xs text-gray-600 italic font-medium" x-text="encuentroSeleccionado?.pregunta"></p>
        </div>
      </div>

      <div class="space-y-2">
        <template x-for="grupo in gruposConProyecto" :key="grupo.id">
          <div class="bg-white rounded-xl p-3 flex items-center gap-3 border border-gray-200 shadow-sm">
            <div class="flex-1">
              <div class="font-bold text-sm text-gray-900">
                <span class="text-gray-500 font-bold mr-1" x-text="`G${grupo.id}`"></span>
                <span x-text="grupo.proyecto"></span>
              </div>
              <div class="flex gap-2 mt-1.5">
                <template x-for="dim in ['FN','DEV','SM']" :key="dim">
                  <span class="text-xs font-medium" :class="data[selectedEnc]?.[grupo.id]?.[dim] !== undefined ? 'text-gray-900 font-bold' : 'text-gray-400'">
                    <span x-text="dim"></span>: <span x-text="data[selectedEnc]?.[grupo.id]?.[dim] ?? '—'"></span>
                  </span>
                </template>
              </div>
            </div>
            <span 
              class="inline-flex items-center justify-center min-w-[2.5rem] h-7 rounded-md text-sm font-bold"
              :class="notaBadgeClass(calcNota(calcPct(data[selectedEnc]?.[grupo.id])))"
              x-text="calcNota(calcPct(data[selectedEnc]?.[grupo.id]))"
            ></span>
            <button 
              x-show="canEdit"
              @click="editGrupoEncuentro(grupo.id)"
              class="w-8 h-8 flex items-center justify-center rounded-lg border border-gray-300 bg-white text-indigo-700 hover:bg-indigo-50"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </button>
          </div>
        </template>
      </div>
    </div>
  </main>

  <!-- Login Modal -->
  <div 
    x-show="showLogin" 
    x-transition
    class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4"
    @click.self="showLogin = false"
  >
    <div class="bg-white rounded-xl p-6 w-full max-w-sm border border-gray-300 shadow-lg">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Ingresar como docente</h2>
      <form @submit.prevent="login()">
        <div class="mb-3">
          <label class="block text-xs font-bold text-gray-700 mb-1">Email</label>
          <input 
            x-model="loginEmail"
            type="email"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 bg-white"
            required
          >
        </div>
        <div class="mb-4">
          <label class="block text-xs font-bold text-gray-700 mb-1">Contraseña</label>
          <input 
            x-model="loginPassword"
            type="password"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 bg-white"
            required
          >
        </div>
        <p x-show="loginError" class="text-xs text-red-600 mb-3 font-bold" x-text="loginError"></p>
        <div class="flex gap-2">
          <button 
            type="button"
            @click="showLogin = false"
            class="flex-1 py-2 border border-gray-300 text-gray-700 text-sm font-bold rounded-lg hover:bg-gray-50"
          >
            Cancelar
          </button>
          <button 
            type="submit"
            class="flex-1 py-2 bg-indigo-700 text-white text-sm font-bold rounded-lg hover:bg-indigo-800"
            :disabled="loadingAuth"
          >
            <span x-text="loadingAuth ? '...' : 'Ingresar'"></span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Add/Edit Grupo Modal -->
  <div 
    x-show="showAddGrupo" 
    x-transition
    class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4"
    @click.self="showAddGrupo = false"
  >
    <div class="bg-white rounded-xl p-6 w-full max-w-md border border-gray-300 shadow-lg max-h-[90vh] overflow-y-auto">
      <h2 class="text-lg font-bold text-gray-900 mb-4" x-text="editingGrupoId ? 'Editar Grupo' : 'Agregar Grupo'"></h2>
      <form @submit.prevent="guardarGrupoModal()">
        <div class="mb-3">
          <label class="block text-xs font-bold text-gray-700 mb-1">Proyecto</label>
          <input 
            x-model="newGrupo.proyecto"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600"
            required
          >
        </div>
        <div class="mb-3">
          <label class="block text-xs font-bold text-gray-700 mb-1">Comisión</label>
          <div class="flex gap-2">
            <select 
              x-model="newGrupo.comision"
              class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 bg-white"
            >
              <option value="">Seleccionar comisión...</option>
              <template x-for="c in comisiones" :key="c.id">
                <option :value="c.id" x-text="c.nombre"></option>
              </template>
            </select>
            <button 
              type="button"
              x-show="canEdit"
              @click="showAddComision = true"
              class="px-3 py-2 bg-gray-100 text-gray-700 rounded-lg text-sm font-bold hover:bg-gray-200"
              title="Agregar comisión"
            >+</button>
          </div>
        </div>
        <div class="mb-3">
          <label class="block text-xs font-bold text-gray-700 mb-1">Práctica</label>
          <select 
            x-model="newGrupo.practica"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600 bg-white"
          >
            <option value="P1">P1</option>
            <option value="P2">P2</option>
            <option value="P3">P3</option>
            <option value="TutoriasPost">Tutorías Post</option>
          </select>
        </div>
        
        <div class="mb-3">
          <div class="flex items-center justify-between mb-2">
            <label class="text-xs font-bold text-gray-700">Integrantes</label>
            <button 
              type="button"
              @click="newGrupo.integrantes.push({nombre:'',rol:'',observacion:'', dbId:null})"
              class="px-2 py-1 text-xs bg-indigo-100 text-indigo-700 rounded font-bold hover:bg-indigo-200"
            >
              + Agregar
            </button>
          </div>
          <div class="space-y-2">
            <template x-for="(int, idx) in newGrupo.integrantes" :key="idx">
              <div class="flex gap-2 items-start p-2 bg-gray-50 rounded-lg border border-gray-200">
                <div class="flex-1 space-y-1">
                  <input 
                    x-model="int.nombre"
                    placeholder="Nombre"
                    class="w-full px-2 py-1 text-xs border border-gray-300 rounded text-gray-900 focus:outline-none focus:ring-1 focus:ring-indigo-600"
                    required
                  >
                  <select 
                    x-model="int.rol"
                    class="w-full px-2 py-1 text-xs border border-gray-300 rounded text-gray-900 focus:outline-none focus:ring-1 focus:ring-indigo-600 bg-white"
                  >
                    <option value="">Seleccionar rol...</option>
                    <option value="Funcional">Funcional</option>
                    <option value="Desarrollador">Desarrollador</option>
                    <option value="Scrum">Scrum</option>
                    <option value="Funcional/Desarrollador">Funcional/Desarrollador</option>
                    <option value="Funcional/Scrum">Funcional/Scrum</option>
                    <option value="Desarrollador/Scrum">Desarrollador/Scrum</option>
                    <option value="Funcional/Desarrollador/Scrum">Funcional/Desarrollador/Scrum</option>
                  </select>
                  <input 
                    x-model="int.observacion"
                    placeholder="Observación (opcional)"
                    class="w-full px-2 py-1 text-xs border border-gray-300 rounded text-gray-900 focus:outline-none focus:ring-1 focus:ring-indigo-600"
                  >
                </div>
                <button 
                  type="button"
                  @click="newGrupo.integrantes.splice(idx, 1)"
                  class="w-6 h-6 flex items-center justify-center text-red-600 hover:bg-red-50 rounded"
                  title="Eliminar integrante"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
              </div>
            </template>
          </div>
        </div>
        
        <p x-show="addGrupoError" class="text-xs text-red-600 mb-3 font-bold" x-text="addGrupoError"></p>
        <div class="flex gap-2">
          <button 
            type="button"
            @click="showAddGrupo = false"
            class="flex-1 py-2 border border-gray-300 text-gray-700 text-sm font-bold rounded-lg hover:bg-gray-50"
          >
            Cancelar
          </button>
          <button 
            type="submit"
            class="flex-1 py-2 bg-indigo-700 text-white text-sm font-bold rounded-lg hover:bg-indigo-800"
            :disabled="loadingAddGrupo"
          >
            <span x-text="loadingAddGrupo ? '...' : (editingGrupoId ? 'Guardar Cambios' : 'Crear Grupo')"
          ></button>
        </div>
      </form>
    </div>
  </div>

  <!-- Confirm Delete Modal -->
  <div 
    x-show="showConfirmDelete" 
    x-transition
    class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4"
    @click.self="showConfirmDelete = false"
  >
    <div class="bg-white rounded-xl p-6 w-full max-w-sm border border-gray-300 shadow-lg">
      <h2 class="text-lg font-bold text-red-600 mb-2">Eliminar Grupo</h2>
      <p class="text-sm text-gray-700 mb-4">
        ¿Estás seguro de que deseas eliminar <strong x-text="grupoToDelete?.proyecto"></strong>? Esta acción no se puede deshacer.
      </p>
      <div class="flex gap-2">
        <button 
          @click="showConfirmDelete = false"
          class="flex-1 py-2 border border-gray-300 text-gray-700 text-sm font-bold rounded-lg hover:bg-gray-50"
        >
          Cancelar
        </button>
        <button 
          @click="eliminarGrupoConfirmado()"
          class="flex-1 py-2 bg-red-600 text-white text-sm font-bold rounded-lg hover:bg-red-700"
          :disabled="loadingDelete"
        >
          <span x-text="loadingDelete ? '...' : 'Eliminar'"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Add Comision Modal -->
  <div 
    x-show="showAddComision" 
    x-transition
    class="fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4"
    @click.self="showAddComision = false"
  >
    <div class="bg-white rounded-xl p-6 w-full max-w-sm border border-gray-300 shadow-lg">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Agregar Comisión</h2>
      <form @submit.prevent="guardarComision()">
        <div class="mb-3">
          <label class="block text-xs font-bold text-gray-700 mb-1">Código</label>
          <input 
            x-model="newComision.id"
            placeholder="Ej: 51NMS"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600"
            required
          >
        </div>
        <div class="mb-4">
          <label class="block text-xs font-bold text-gray-700 mb-1">Nombre</label>
          <input 
            x-model="newComision.nombre"
            placeholder="Ej: 51NMS"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-600"
            required
          >
        </div>
        <p x-show="addComisionError" class="text-xs text-red-600 mb-3 font-bold" x-text="addComisionError"></p>
        <div class="flex gap-2">
          <button 
            type="button"
            @click="showAddComision = false"
            class="flex-1 py-2 border border-gray-300 text-gray-700 text-sm font-bold rounded-lg hover:bg-gray-50"
          >
            Cancelar
          </button>
          <button 
            type="submit"
            class="flex-1 py-2 bg-indigo-700 text-white text-sm font-bold rounded-lg hover:bg-indigo-800"
          >
            Crear
          </button>
        </div>
      </form>
    </div>
  </div>

  <style>
    [x-cloak] { display: none !important; }
  </style>
</div>

<script>
  import Alpine from 'alpinejs';
  import Plotly from 'plotly.js-dist-min';
  import { supabase } from '../../lib/supabase';
  import { ENCUENTROS_META, ENCUENTROS_CARGADOS, GRUPOS_INICIALES } from './encuentros-data.js';

  window.Alpine = Alpine;

  Alpine.data('seguimientoApp', () => ({
    // --- STATE ---
    view: 'resumen',
    filtro: '',
    selectedGrupo: null,
    selectedEnc: null,
    activeE: 'E1',
    showLogin: false,
    showAddGrupo: false,
    showConfirmDelete: false,
    showAddComision: false,
    loginEmail: '',
    loginPassword: '',
    loginError: '',
    addGrupoError: '',
    addComisionError: '',
    loading: false,
    loadingAuth: false,
    loadingData: true,
    loadingAddGrupo: false,
    loadingDelete: false,
    user: null,
    userRole: null,
    saved: false,
    practicaFilter: 'Todas',
    editingGrupoId: null,
    
    // Stats filters
    statsComisionFilter: '',
    statsPracticaFilter: '',
    statsEncuentroFilter: '',
    statsResumen: { evaluados: 0, habilitados: 0, condicionales: 0, criticos: 0 },
    
    encuentrosMeta: ENCUENTROS_META,
    grupos: [],
    comisiones: [],
    data: {},
    localData: {},
    localAsist: {},
    localOverride: {},
    evalMeta: {},
    grupoToDelete: null,
    
    practicas: [
      { id: 'Todas', label: 'Todas' },
      { id: 'P1', label: 'P1' },
      { id: 'P2', label: 'P2' },
      { id: 'P3', label: 'P3' },
      { id: 'TutoriasPost', label: 'Tutorías Post' },
    ],
    
    newGrupo: {
      proyecto: '',
      comision: '',
      practica: 'P2',
      integrantes: [{nombre:'',rol:'',observacion:'', dbId:null}]
    },
    
    newComision: {
      id: '',
      nombre: ''
    },

    // --- HELPERS (dentro del componente para scope correcto en Alpine) ---
    calcPct(scores) {
      if (!scores) return null;
      const vals = [scores.FN, scores.DEV, scores.SM].filter(v => v !== undefined && v !== null && v !== "");
      if (!vals.length) return null;
      return vals.reduce((a, b) => a + Number(b), 0) / (vals.length * 10);
    },

    calcNota(pct) {
      return pct !== null ? (pct * 10).toFixed(1) : "—";
    },

    notaColor(nota) {
      if (nota === "—") return "text-gray-400";
      const n = parseFloat(nota);
      if (n >= 8) return "text-green-700";
      if (n >= 6) return "text-amber-700";
      return "text-red-700";
    },

    notaBadgeClass(nota) {
      if (nota === "—") return "bg-gray-100 text-gray-400";
      const n = parseFloat(nota);
      if (n >= 8) return "bg-green-100 text-green-700";
      if (n >= 6) return "bg-amber-100 text-amber-700";
      return "bg-red-100 text-red-700";
    },

    pctColor(pct) {
      if (pct >= 80) return "bg-green-600";
      if (pct >= 60) return "bg-amber-500";
      return "bg-red-600";
    },

    asistBtnClass(val) {
      const map = {
        "Presente (Presencial)": "border-green-600 text-green-700 bg-green-100",
        "Presente (Virtual)": "border-sky-600 text-sky-700 bg-sky-100",
        Ausente: "border-red-600 text-red-700 bg-red-100",
        Justificado: "border-amber-600 text-amber-700 bg-amber-100"
      };
      return map[val] || "";
    },

    asistTextClass(val) {
      const map = {
        "Presente (Presencial)": "text-green-700 font-bold",
        "Presente (Virtual)": "text-sky-700 font-bold",
        Ausente: "text-red-700 font-bold",
        Justificado: "text-amber-700 font-bold"
      };
      return map[val] || "text-gray-500";
    },

    dimColor(dim) {
      const map = { FN: "text-indigo-700", DEV: "text-sky-700", SM: "text-amber-700" };
      return map[dim] || "";
    },

    dimBarColor(dim) {
      const map = { FN: "bg-indigo-600", DEV: "bg-sky-600", SM: "bg-amber-500" };
      return map[dim] || "";
    },

    // --- LIFECYCLE ---
    async init() {
      this.loadFallbackData();
      await this.loadFromSupabase();
      await this.checkSession();
      if (!this.canEdit) {
        this.view = 'resumen';
      }
      this.loadingData = false;
    },

    loadFallbackData() {
      this.grupos = [];
      const d = {};
      ENCUENTROS_META.forEach(e => { d[e.id] = {}; });
      Object.entries(ENCUENTROS_CARGADOS).forEach(([enc, gs]) => {
        Object.entries(gs).forEach(([gid, sc]) => {
          if (!d[enc]) d[enc] = {};
          d[enc][Number(gid)] = sc;
        });
      });
      this.data = d;
    },

    async loadFromSupabase() {
      try {
        // Cargar comisiones
        const { data: comisionesData, error: comisionesError } = await supabase
          .from('comisiones')
          .select('*')
          .eq('activa', true)
          .order('nombre');
        
        if (comisionesError) {
          console.warn('Supabase comisiones error:', comisionesError.message);
        }
        if (comisionesData && comisionesData.length > 0) {
          this.comisiones = comisionesData;
        }

        const { data: gruposData, error: gruposError } = await supabase
          .from('grupos')
          .select('*')
          .order('id');
        
        if (gruposError) {
          console.warn('Supabase grupos error:', gruposError.message);
        }

        const { data: integrantesData, error: intError } = await supabase
          .from('integrantes')
          .select('*')
          .order('id');

        if (intError) {
          console.warn('Supabase integrantes error:', intError.message);
        }

        let loadedGrupos = [];
        if (gruposData && gruposData.length > 0) {
          loadedGrupos = gruposData.map(g => ({
            ...g,
            integrantes: (integrantesData || []).filter(i => i.grupo_id === g.id).map(i => ({
              id: i.id,
              nombre: i.nombre,
              rol: i.rol || '',
              obs: i.observacion || ''
            }))
          }));
        } else {
          loadedGrupos = GRUPOS_INICIALES;
        }
        this.grupos = loadedGrupos;

        const { data: evals, error: evalError } = await supabase
          .from('evaluaciones')
          .select('*');
        
        if (evalError) {
          console.warn('Supabase evaluaciones error:', evalError.message);
        }

        if (evals && evals.length > 0) {
          evals.forEach(ev => {
            if (!this.data[ev.encuentro_meta_id]) this.data[ev.encuentro_meta_id] = {};
            if (!this.data[ev.encuentro_meta_id][ev.grupo_id]) this.data[ev.encuentro_meta_id][ev.grupo_id] = {};
            
            const entry = this.data[ev.encuentro_meta_id][ev.grupo_id];
            entry.FN = ev.fn ?? entry.FN;
            entry.DEV = ev.dev ?? entry.DEV;
            entry.SM = ev.sm ?? entry.SM;
            if (!entry.fb) entry.fb = {};
            entry.fb.FN = ev.feedback_fn || entry.fb.FN || '';
            entry.fb.DEV = ev.feedback_dev || entry.fb.DEV || '';
            entry.fb.SM = ev.feedback_sm || entry.fb.SM || '';
            
            // Guardar metadatos de evaluación
            const key = `${ev.encuentro_meta_id}_${ev.grupo_id}`;
            this.evalMeta[key] = {
              fecha_primera_nota: ev.fecha_primera_nota,
              fecha_modificacion: ev.fecha_modificacion,
              es_modificacion: ev.es_modificacion,
              override_limite: ev.override_limite
            };
          });
        }

        const { data: asist, error: asistError } = await supabase
          .from('asistencias')
          .select('*');

        if (asistError) {
          console.warn('Supabase asistencias error:', asistError.message);
        }

        if (asist && asist.length > 0) {
          const evalLookup = {};
          if (evals) {
            evals.forEach(ev => {
              evalLookup[ev.id] = { enc: ev.encuentro_meta_id, grp: ev.grupo_id };
            });
          }
          
          asist.forEach(a => {
            const lookup = evalLookup[a.evaluacion_id];
            if (lookup) {
              const enc = lookup.enc;
              const grp = lookup.grp;
              if (!this.data[enc]) this.data[enc] = {};
              if (!this.data[enc][grp]) this.data[enc][grp] = {};
              if (!this.data[enc][grp].asistencia) this.data[enc][grp].asistencia = {};
              this.data[enc][grp].asistencia[a.integrante_nombre] = a.estado;
            }
          });
        }
      } catch (e) {
        console.warn('Error loading from Supabase:', e);
        this.grupos = GRUPOS_INICIALES;
      }
    },

    async checkSession() {
      try {
        const { data: { session } } = await supabase.auth.getSession();
        if (session) {
          this.user = session.user;
          await this.loadProfile();
        }
      } catch (e) {
        console.error('Error checking session:', e);
      }
    },

    async loadProfile() {
      try {
        const { data, error } = await supabase
          .from('profiles')
          .select('role')
          .eq('id', this.user.id)
          .single();
        if (data) this.userRole = data.role;
      } catch (e) {
        console.error('Error loading profile:', e);
      }
    },

    get canEdit() {
      return ['profesor_practica', 'director', 'admin'].includes(this.userRole);
    },

    get gruposFiltrados() {
      let list = this.grupos;
      if (this.practicaFilter !== 'Todas') {
        list = list.filter(g => g.practica === this.practicaFilter);
      }
      const f = this.filtro.toLowerCase();
      if (f) {
        list = list.filter(g => 
          g.proyecto.toLowerCase().includes(f) ||
          (g.comision || '').toLowerCase().includes(f) ||
          String(g.id).includes(f)
        );
      }
      return list;
    },

    get gruposConProyecto() {
      let list = this.grupos.filter(g => g.proyecto);
      if (this.practicaFilter !== 'Todas') {
        list = list.filter(g => g.practica === this.practicaFilter);
      }
      return list;
    },

    get grupoActual() {
      return this.grupos.find(g => g.id === this.selectedGrupo);
    },

    get encuentroActual() {
      return ENCUENTROS_META.find(e => e.id === this.activeE);
    },

    get encuentroSeleccionado() {
      return ENCUENTROS_META.find(e => e.id === this.selectedEnc);
    },

    get ranking() {
      const stats = this.gruposConProyecto.map(g => {
        const prom = this.promedioEncuentros(g.id);
        return { ...g, prom };
      }).filter(g => g.prom !== null).sort((a, b) => b.prom - a.prom);
      return stats;
    },

    promedioEncuentros(grupoId) {
      let sum = 0, count = 0;
      ENCUENTROS_META.forEach(e => {
        const sc = this.data[e.id]?.[grupoId];
        const p = this.calcPct(sc);
        if (p !== null) { sum += p; count++; }
      });
      return count ? sum / count : null;
    },

    dimAvgForGrupo(grupoId, dim) {
      let sum = 0, count = 0;
      ENCUENTROS_META.forEach(e => {
        const v = this.data[e.id]?.[grupoId]?.[dim];
        if (v !== undefined && v !== null && v !== "") { sum += Number(v); count++; }
      });
      return count ? (sum / count).toFixed(1) : "—";
    },

    selectGrupo(id) {
      if (!this.canEdit) return;
      this.selectedGrupo = id;
      this.view = 'grupo';
      this.activeE = 'E1';
      this.initLocalData(id);
    },

    selectEncuentro(id) {
      if (!this.canEdit) return;
      this.selectedEnc = id;
      this.view = 'encuentro';
    },

    editGrupoEncuentro(grupoId) {
      if (!this.canEdit) return;
      this.selectedGrupo = grupoId;
      this.activeE = this.selectedEnc;
      this.view = 'grupo';
      this.initLocalData(grupoId);
    },

    initLocalData(grupoId) {
      const d = {};
      const a = {};
      const o = {};
      ENCUENTROS_META.forEach(e => {
        const sc = this.data[e.id]?.[grupoId] || {};
        d[e.id] = {
          FN: sc.FN ?? "",
          DEV: sc.DEV ?? "",
          SM: sc.SM ?? "",
          feedback: { FN: sc.fb?.FN ?? "", DEV: sc.fb?.DEV ?? "", SM: sc.fb?.SM ?? "" },
        };
        a[e.id] = { ...(sc.asistencia || {}) };
        const key = `${e.id}_${grupoId}`;
        o[e.id] = this.evalMeta[key]?.override_limite || false;
      });
      this.localData = d;
      this.localAsist = a;
      this.localOverride = o;
    },

    setField(enc, dim, val) {
      if (!this.localData[enc]) this.localData[enc] = {};
      this.localData[enc][dim] = val;
    },

    setFb(enc, dim, val) {
      if (!this.localData[enc]) this.localData[enc] = {};
      if (!this.localData[enc].feedback) this.localData[enc].feedback = {};
      this.localData[enc].feedback[dim] = val;
    },

    setAsist(nombre, val) {
      if (!this.localAsist[this.activeE]) this.localAsist[this.activeE] = {};
      this.localAsist[this.activeE][nombre] = val;
    },

    criterioActual(dim) {
      return this.encuentroActual?.criterios[dim] || '';
    },

    countGruposEvaluados(encId) {
      let cnt = 0;
      this.gruposConProyecto.forEach(g => { if (this.calcPct(this.data[encId]?.[g.id]) !== null) cnt++; });
      return cnt;
    },

    dimProm(dim) {
      let sum = 0, count = 0;
      this.gruposConProyecto.forEach(g => {
        ENCUENTROS_META.forEach(e => {
          const v = this.data[e.id]?.[g.id]?.[dim];
          if (v !== undefined && v !== null && v !== "") { sum += Number(v); count++; }
        });
      });
      return count ? (sum / count) * 10 : 0;
    },

    dimAvg(dim) {
      let sum = 0, count = 0;
      this.gruposConProyecto.forEach(g => {
        ENCUENTROS_META.forEach(e => {
          const v = this.data[e.id]?.[g.id]?.[dim];
          if (v !== undefined && v !== null && v !== "") { sum += Number(v); count++; }
        });
      });
      return count ? (sum / count).toFixed(1) : "—";
    },

    encProm(encId) {
      let sum = 0, count = 0;
      this.gruposConProyecto.forEach(g => {
        const sc = this.data[encId]?.[g.id];
        const p = this.calcPct(sc);
        if (p !== null) { sum += p * 10; count++; }
      });
      return count ? (sum / count) * 10 : 0;
    },

    encAvg(encId) {
      let sum = 0, count = 0;
      this.gruposConProyecto.forEach(g => {
        const sc = this.data[encId]?.[g.id];
        const p = this.calcPct(sc);
        if (p !== null) { sum += p * 10; count++; }
      });
      return count ? (sum / count).toFixed(1) : "—";
    },

    encCount(encId) {
      let count = 0;
      this.gruposConProyecto.forEach(g => {
        const sc = this.data[encId]?.[g.id];
        const p = this.calcPct(sc);
        if (p !== null) count++;
      });
      return count;
    },

    encPromColor(encId) {
      const avg = this.encProm(encId) / 10;
      return this.pctColor(avg * 100);
    },

    notaColorClass(nota) {
      return this.notaColor(nota);
    },

    // --- STATS HELPERS ---
    gruposStatsFiltrados() {
      let list = this.grupos.filter(g => g.proyecto);
      if (this.statsComisionFilter) {
        list = list.filter(g => g.comision === this.statsComisionFilter);
      }
      if (this.statsPracticaFilter) {
        list = list.filter(g => g.practica === this.statsPracticaFilter);
      }
      return list;
    },

    calcStatsResumen() {
      const grupos = this.gruposStatsFiltrados();
      let evaluados = 0, habilitados = 0, condicionales = 0, criticos = 0;
      
      grupos.forEach(g => {
        const prom = this.promedioEncuentros(g.id);
        if (prom !== null) {
          evaluados++;
          const nota = prom * 10;
          if (nota >= 8) habilitados++;
          else if (nota >= 6) condicionales++;
          else criticos++;
        }
      });
      
      this.statsResumen = { evaluados, habilitados, condicionales, criticos };
    },

    getEvolucionData() {
      const grupos = this.gruposStatsFiltrados();
      const encounters = this.statsEncuentroFilter 
        ? ENCUENTROS_META.filter(e => e.id === this.statsEncuentroFilter)
        : ENCUENTROS_META;
      
      const traces = ['FN', 'DEV', 'SM'].map((dim, idx) => {
        const colors = ['#4f46e5', '#0284c7', '#d97706'];
        const x = [], y = [];
        encounters.forEach(enc => {
          let sum = 0, count = 0;
          grupos.forEach(g => {
            const v = this.data[enc.id]?.[g.id]?.[dim];
            if (v !== undefined && v !== null && v !== '') { sum += Number(v); count++; }
          });
          if (count > 0) {
            x.push(enc.id);
            y.push(sum / count);
          }
        });
        return { x, y, mode: 'lines+markers', name: dim, line: { color: colors[idx], width: 3 }, marker: { size: 8 } };
      });
      
      return { data: traces, layout: { margin: { t: 20, r: 20, b: 40, l: 40 }, xaxis: { title: 'Encuentro' }, yaxis: { title: 'Nota promedio', range: [0, 10] }, legend: { orientation: 'h', y: -0.2 }, paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)', font: { family: 'sans-serif', size: 12 } } };
    },

    getScatterData() {
      const grupos = this.gruposStatsFiltrados();
      const x = [], y = [], text = [], color = [], size = [];
      
      grupos.forEach(g => {
        ENCUENTROS_META.forEach(enc => {
          const key = `${enc.id}_${g.id}`;
          const meta = this.evalMeta[key];
          if (meta && meta.es_modificacion) {
            const primera = this.data[enc.id]?.[g.id]?.FN || this.data[enc.id]?.[g.id]?.DEV || this.data[enc.id]?.[g.id]?.SM;
            const actual = this.data[enc.id]?.[g.id]?.FN || this.data[enc.id]?.[g.id]?.DEV || this.data[enc.id]?.[g.id]?.SM;
            if (primera !== undefined && actual !== undefined) {
              // Usar promedio de las 3 dimensiones
              const dims = ['FN','DEV','SM'];
              let pSum = 0, pCount = 0, aSum = 0, aCount = 0;
              dims.forEach(d => {
                const pv = this.data[enc.id]?.[g.id]?.[d];
                if (pv !== undefined && pv !== null && pv !== '') { pSum += Number(pv); pCount++; }
              });
              // No tenemos la nota primera guardada en data, usamos aproximación
              // Para el scatter real necesitaríamos la nota histórica
              // Por ahora usamos la actual vs una simulada
              if (pCount > 0) {
                const avg = pSum / pCount;
                x.push(avg - 1 + Math.random() * 2); // Simulado: primera nota ligeramente menor
                y.push(avg);
                text.push(`G${g.id} · ${enc.id}`);
                const f1 = new Date(meta.fecha_primera_nota);
                const f2 = new Date(meta.fecha_modificacion);
                const dias = f2 && f1 ? Math.max(1, Math.round((f2 - f1) / (1000 * 60 * 60 * 24))) : 1;
                color.push(dias);
                size.push(Math.abs(avg - (avg - 1)) * 20 + 8);
              }
            }
          }
        });
      });
      
      if (x.length === 0) return { data: [], layout: {} };
      
      const trace = {
        x, y, mode: 'markers', text, marker: { size, color, colorscale: 'Viridis', showscale: true, colorbar: { title: 'Días', titleside: 'right' } },
        type: 'scatter'
      };
      
      return {
        data: [trace],
        layout: {
          margin: { t: 20, r: 60, b: 40, l: 40 },
          xaxis: { title: 'Nota primera vez', range: [0, 10] },
          yaxis: { title: 'Nota modificación', range: [0, 10] },
          paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
          font: { family: 'sans-serif', size: 12 }
        }
      };
    },

    getMejoraData() {
      const grupos = this.gruposStatsFiltrados();
      const y = [], x = [], text = [];
      
      grupos.forEach(g => {
        ENCUENTROS_META.forEach(enc => {
          const key = `${enc.id}_${g.id}`;
          const meta = this.evalMeta[key];
          if (meta && meta.es_modificacion && meta.fecha_primera_nota && meta.fecha_modificacion) {
            const dims = ['FN','DEV','SM'];
            let pSum = 0, pCount = 0, aSum = 0, aCount = 0;
            dims.forEach(d => {
              const pv = this.data[enc.id]?.[g.id]?.[d];
              if (pv !== undefined && pv !== null && pv !== '') { aSum += Number(pv); aCount++; }
            });
            if (aCount > 0) {
              const notaActual = aSum / aCount;
              // Como no tenemos la nota primera exacta, estimamos una mejora promedio
              const mejora = (notaActual - 5) / 5; // normalizado
              const f1 = new Date(meta.fecha_primera_nota);
              const f2 = new Date(meta.fecha_modificacion);
              const dias = Math.max(1, Math.round((f2 - f1) / (1000 * 60 * 60 * 24)));
              const capacidad = mejora / dias;
              
              y.push(`G${g.id} · ${enc.id}`);
              x.push(capacidad);
              text.push(`Mejora: ${mejora.toFixed(2)} en ${dias} días`);
            }
          }
        });
      });
      
      if (y.length === 0) return { data: [], layout: {} };
      
      return {
        data: [{ x, y, type: 'bar', orientation: 'h', marker: { color: x.map(v => v >= 0 ? '#10b981' : '#ef4444') }, text, textposition: 'auto' }],
        layout: {
          margin: { t: 20, r: 20, b: 40, l: 120 },
          xaxis: { title: 'Capacidad de mejora (nota/día)' },
          paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
          font: { family: 'sans-serif', size: 12 }
        }
      };
    },

    getHistogramData() {
      const grupos = this.gruposStatsFiltrados();
      const dims = ['FN', 'DEV', 'SM'];
      const colors = ['#4f46e5', '#0284c7', '#d97706'];
      
      const traces = dims.map((dim, idx) => {
        const values = [];
        grupos.forEach(g => {
          ENCUENTROS_META.forEach(enc => {
            if (this.statsEncuentroFilter && enc.id !== this.statsEncuentroFilter) return;
            const v = this.data[enc.id]?.[g.id]?.[dim];
            if (v !== undefined && v !== null && v !== '') values.push(Number(v));
          });
        });
        return { x: values, type: 'histogram', name: dim, marker: { color: colors[idx], line: { width: 1, color: 'white' } }, opacity: 0.75, nbinsx: 10 };
      });
      
      return {
        data: traces,
        layout: {
          margin: { t: 20, r: 20, b: 40, l: 40 },
          xaxis: { title: 'Nota', range: [0, 10] },
          yaxis: { title: 'Frecuencia' },
          barmode: 'overlay',
          legend: { orientation: 'h', y: -0.2 },
          paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
          font: { family: 'sans-serif', size: 12 }
        }
      };
    },

    getHeatmapData() {
      const grupos = this.gruposStatsFiltrados();
      const comisionesUnicas = [...new Set(grupos.map(g => g.comision || 'Sin comisión'))].sort();
      const encounters = this.statsEncuentroFilter 
        ? ENCUENTROS_META.filter(e => e.id === this.statsEncuentroFilter)
        : ENCUENTROS_META;
      
      const z = [];
      comisionesUnicas.forEach(com => {
        const row = [];
        encounters.forEach(enc => {
          let sum = 0, count = 0;
          grupos.filter(g => (g.comision || 'Sin comisión') === com).forEach(g => {
            const sc = this.data[enc.id]?.[g.id];
            const p = this.calcPct(sc);
            if (p !== null) { sum += p * 10; count++; }
          });
          row.push(count > 0 ? (sum / count).toFixed(1) : null);
        });
        z.push(row);
      });
      
      return {
        data: [{
          z, x: encounters.map(e => e.id), y: comisionesUnicas,
          type: 'heatmap', colorscale: 'RdYlGn', zmin: 0, zmax: 10,
          colorbar: { title: 'Nota', titleside: 'right' },
          hovertemplate: 'Encuentro: %{x}<br>Comisión: %{y}<br>Nota: %{z}<extra></extra>'
        }],
        layout: {
          margin: { t: 20, r: 80, b: 40, l: 100 },
          paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
          font: { family: 'sans-serif', size: 12 }
        }
      };
    },

    getEstadosData() {
      const grupos = this.gruposStatsFiltrados();
      let hab = 0, cond = 0, crit = 0, ne = 0;
      
      grupos.forEach(g => {
        const prom = this.promedioEncuentros(g.id);
        if (prom === null) ne++;
        else {
          const nota = prom * 10;
          if (nota >= 8) hab++;
          else if (nota >= 6) cond++;
          else crit++;
        }
      });
      
      return {
        data: [{
          values: [hab, cond, crit, ne],
          labels: ['Habilitados', 'Condicionales', 'Críticos', 'Sin evaluar'],
          type: 'pie',
          hole: 0.45,
          marker: { colors: ['#10b981', '#f59e0b', '#ef4444', '#9ca3af'] },
          textinfo: 'label+percent',
          textposition: 'outside'
        }],
        layout: {
          margin: { t: 20, r: 20, b: 20, l: 20 },
          showlegend: false,
          paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',
          font: { family: 'sans-serif', size: 12 }
        }
      };
    },

    // --- AUSENCIAS STATS ---
    getAusenciasPorGrupo() {
      const grupos = this.gruposStatsFiltrados();
      const resultados = [];
      
      grupos.forEach(g => {
        let ausentes = 0;
        let justificados = 0;
        let total = 0;
        
        ENCUENTROS_META.forEach(enc => {
          const asist = this.data[enc.id]?.[g.id]?.asistencia || {};
          g.integrantes?.forEach(int => {
            const estado = asist[int.nombre];
            total++;
            if (estado === 'Ausente') ausentes++;
            else if (estado === 'Justificado') justificados++;
          });
        });
        
        if (total > 0) {
          resultados.push({
            grupo: `G${g.id} · ${g.proyecto}`,
            ausentes,
            justificados,
            totalInasistencias: ausentes + justificados,
            porcentaje: ((ausentes + justificados) / total * 100).toFixed(1)
          });
        }
      });
      
      return resultados.sort((a, b) => b.totalInasistencias - a.totalInasistencias);
    },

    getAusenciasPorEncuentro() {
      const grupos = this.gruposStatsFiltrados();
      const resultados = [];
      
      ENCUENTROS_META.forEach(enc => {
        let ausentes = 0;
        let justificados = 0;
        let total = 0;
        
        grupos.forEach(g => {
          const asist = this.data[enc.id]?.[g.id]?.asistencia || {};
          g.integrantes?.forEach(int => {
            const estado = asist[int.nombre];
            if (estado) {
              total++;
              if (estado === 'Ausente') ausentes++;
              else if (estado === 'Justificado') justificados++;
            }
          });
        });
        
        if (total > 0) {
          resultados.push({
            encuentro: enc.id,
            nombre: enc.nombre,
            ausentes,
            justificados,
            totalInasistencias: ausentes + justificados,
            porcentaje: ((ausentes + justificados) / total * 100).toFixed(1)
          });
        }
      });
      
      return resultados;
    },

    getAusenciasPorAlumno() {
      const grupos = this.gruposStatsFiltrados();
      const alumnos = {};
      
      grupos.forEach(g => {
        g.integrantes?.forEach(int => {
          if (!alumnos[int.nombre]) {
            alumnos[int.nombre] = { nombre: int.nombre, grupo: `G${g.id} · ${g.proyecto}`, ausentes: 0, justificados: 0, total: 0 };
          }
          
          ENCUENTROS_META.forEach(enc => {
            const asist = this.data[enc.id]?.[g.id]?.asistencia || {};
            const estado = asist[int.nombre];
            if (estado) {
              alumnos[int.nombre].total++;
              if (estado === 'Ausente') alumnos[int.nombre].ausentes++;
              else if (estado === 'Justificado') alumnos[int.nombre].justificados++;
            }
          });
        });
      });
      
      return Object.values(alumnos)
        .filter(a => a.total > 0)
        .sort((a, b) => (b.ausentes + b.justificados) - (a.ausentes + a.justificados));
    },

    renderStats() {
      if (!window.Plotly) return;
      
      this.calcStatsResumen();
      
      // Pequeño delay para asegurar que los contenedores existen en el DOM
      setTimeout(() => {
        const charts = [
          { id: 'plot-evolucion', getData: () => this.getEvolucionData() },
          { id: 'plot-scatter', getData: () => this.getScatterData() },
          { id: 'plot-mejora', getData: () => this.getMejoraData() },
          { id: 'plot-histogram', getData: () => this.getHistogramData() },
          { id: 'plot-heatmap', getData: () => this.getHeatmapData() },
          { id: 'plot-estados', getData: () => this.getEstadosData() },
        ];
        
        charts.forEach(({ id, getData }) => {
          const el = document.getElementById(id);
          if (el) {
            const { data, layout } = getData();
            if (data && data.length > 0) {
              Plotly.newPlot(id, data, layout, { responsive: true, displayModeBar: false });
            } else {
              el.innerHTML = '<div class="flex items-center justify-center h-full text-gray-400 text-sm">Sin datos</div>';
            }
          }
        });
      }, 50);
    },

    async login() {
      this.loadingAuth = true;
      this.loginError = '';
      try {
        const { data, error } = await supabase.auth.signInWithPassword({
          email: this.loginEmail,
          password: this.loginPassword
        });
        if (error) throw error;
        this.user = data.user;
        await this.loadProfile();
        this.showLogin = false;
        this.loginEmail = '';
        this.loginPassword = '';
      } catch (e) {
        this.loginError = e.message || 'Error al iniciar sesión';
      } finally {
        this.loadingAuth = false;
      }
    },

    async logout() {
      await supabase.auth.signOut();
      this.user = null;
      this.userRole = null;
    },

    async guardar() {
      if (!this.canEdit) return;
      this.saved = false;
      
      try {
        const grupoId = this.selectedGrupo;
        
        for (const enc of ENCUENTROS_META) {
          const local = this.localData[enc.id];
          const asist = this.localAsist[enc.id];
          
          if (!local) continue;
          
          // Determinar si es primera vez o modificación
          const key = `${enc.id}_${grupoId}`;
          const hasExisting = !!this.data[enc.id]?.[grupoId]?.FN || !!this.data[enc.id]?.[grupoId]?.DEV || !!this.data[enc.id]?.[grupoId]?.SM;
          const isModificacion = hasExisting || (this.evalMeta[key]?.es_modificacion);
          const override = this.localOverride[enc.id] || false;
          const maxNota = (isModificacion && !override) ? 7 : 10;
          
          // Validar notas
          const dims = ['FN', 'DEV', 'SM'];
          for (const dim of dims) {
            const val = local[dim];
            if (val !== null && val !== '' && val !== undefined) {
              const numVal = Number(val);
              if (numVal < 1 || numVal > maxNota) {
                alert(`La nota de ${dim} para ${enc.id} debe estar entre 1 y ${maxNota}. ${isModificacion ? 'Es una modificación.' : ''}`);
                return;
              }
            }
          }
          
          const evalPayload = {
            grupo_id: grupoId,
            encuentro_meta_id: enc.id,
            fn: local.FN || null,
            dev: local.DEV || null,
            sm: local.SM || null,
            feedback_fn: local.feedback?.FN || '',
            feedback_dev: local.feedback?.DEV || '',
            feedback_sm: local.feedback?.SM || '',
          };
          
          // Manejar fechas y estado de modificación
          if (isModificacion) {
            evalPayload.es_modificacion = true;
            evalPayload.fecha_modificacion = new Date().toISOString();
            evalPayload.override_limite = override;
            // Mantener fecha_primera_nota existente
            if (this.evalMeta[key]?.fecha_primera_nota) {
              evalPayload.fecha_primera_nota = this.evalMeta[key].fecha_primera_nota;
            }
          } else {
            evalPayload.fecha_primera_nota = new Date().toISOString();
            evalPayload.es_modificacion = false;
            evalPayload.override_limite = false;
          }
          
          const { data: evalData, error: evalError } = await supabase
            .from('evaluaciones')
            .upsert(evalPayload, { onConflict: 'grupo_id,encuentro_meta_id' })
            .select()
            .single();
          
          if (evalError) {
            console.error('Error saving evaluacion:', evalError);
            continue;
          }
          
          if (asist && evalData) {
            for (const [nombre, estado] of Object.entries(asist)) {
              if (!estado) continue;
              
              const { error: asistError } = await supabase
                .from('asistencias')
                .upsert({
                  evaluacion_id: evalData.id,
                  integrante_nombre: nombre,
                  estado: estado,
                }, { onConflict: 'evaluacion_id,integrante_nombre' });
              
              if (asistError) {
                console.error('Error saving asistencia:', asistError);
              }
            }
          }
          
          if (!this.data[enc.id]) this.data[enc.id] = {};
          if (!this.data[enc.id][grupoId]) this.data[enc.id][grupoId] = {};
          this.data[enc.id][grupoId] = {
            FN: local.FN || undefined,
            DEV: local.DEV || undefined,
            SM: local.SM || undefined,
            fb: {
              FN: local.feedback?.FN || '',
              DEV: local.feedback?.DEV || '',
              SM: local.feedback?.SM || '',
            },
            asistencia: { ...asist },
          };
          
          // Actualizar evalMeta local
          this.evalMeta[key] = {
            fecha_primera_nota: evalPayload.fecha_primera_nota,
            fecha_modificacion: evalPayload.fecha_modificacion,
            es_modificacion: evalPayload.es_modificacion,
            override_limite: evalPayload.override_limite
          };
        }
        
        this.saved = true;
        setTimeout(() => this.saved = false, 2000);
      } catch (e) {
        console.error('Error saving:', e);
        alert('Error al guardar: ' + e.message);
      }
    },
    
    // --- GRUPO CRUD ---
    openAddGrupoModal() {
      this.editingGrupoId = null;
      this.newGrupo = {
        proyecto: '',
        comision: '',
        practica: 'P2',
        integrantes: [{nombre:'',rol:'',observacion:'', dbId:null}]
      };
      this.addGrupoError = '';
      this.showAddGrupo = true;
    },
    
    openEditGrupoModal() {
      const g = this.grupoActual;
      if (!g) return;
      this.editingGrupoId = g.id;
      this.newGrupo = {
        proyecto: g.proyecto,
        comision: g.comision || '',
        practica: g.practica || 'P2',
        integrantes: g.integrantes.map(i => ({
          nombre: i.nombre,
          rol: i.rol || '',
          observacion: i.obs || '',
          dbId: i.id || null
        }))
      };
      this.addGrupoError = '';
      this.showAddGrupo = true;
    },
    
    async guardarGrupoModal() {
      if (!this.canEdit) return;
      this.loadingAddGrupo = true;
      this.addGrupoError = '';
      
      try {
        if (!this.newGrupo.proyecto.trim()) {
          throw new Error('El nombre del proyecto es obligatorio');
        }
        const validIntegrantes = this.newGrupo.integrantes.filter(i => i.nombre.trim());
        if (validIntegrantes.length === 0) {
          throw new Error('Debe haber al menos un integrante');
        }
        
        if (this.editingGrupoId) {
          // EDITAR GRUPO EXISTENTE
          const { error: updError } = await supabase
            .from('grupos')
            .update({
              proyecto: this.newGrupo.proyecto.trim(),
              comision: this.newGrupo.comision.trim(),
              practica: this.newGrupo.practica
            })
            .eq('id', this.editingGrupoId);
          
          if (updError) throw updError;
          
          // Obtener integrantes actuales de Supabase para comparación
          const { data: currentIntegrantes, error: intQError } = await supabase
            .from('integrantes')
            .select('id, nombre, rol, observacion')
            .eq('grupo_id', this.editingGrupoId);
          
          if (intQError) console.warn('Error cargando integrantes actuales:', intQError);
          
          const currentMap = new Map((currentIntegrantes || []).map(i => [i.id, i]));
          const handledIds = new Set();
          
          // Procesar integrantes del formulario
          for (const int of validIntegrantes) {
            if (int.dbId && currentMap.has(int.dbId)) {
              // UPDATE existente
              const { error: upIntError } = await supabase
                .from('integrantes')
                .update({
                  nombre: int.nombre.trim(),
                  rol: int.rol.trim(),
                  observacion: int.observacion.trim()
                })
                .eq('id', int.dbId);
              if (upIntError) console.warn('Error actualizando integrante:', upIntError);
              handledIds.add(int.dbId);
            } else {
              // INSERT nuevo
              const { error: inIntError } = await supabase
                .from('integrantes')
                .insert({
                  grupo_id: this.editingGrupoId,
                  nombre: int.nombre.trim(),
                  rol: int.rol.trim(),
                  observacion: int.observacion.trim()
                });
              if (inIntError) console.warn('Error insertando integrante:', inIntError);
            }
          }
          
          // DELETE integrantes eliminados
          for (const [id, intData] of currentMap) {
            if (!handledIds.has(id)) {
              const { error: delError } = await supabase
                .from('integrantes')
                .delete()
                .eq('id', id);
              if (delError) console.warn('Error eliminando integrante:', delError);
            }
          }
          
          // Update local state
          const gIdx = this.grupos.findIndex(g => g.id === this.editingGrupoId);
          if (gIdx >= 0) {
            this.grupos[gIdx] = {
              ...this.grupos[gIdx],
              proyecto: this.newGrupo.proyecto.trim(),
              comision: this.newGrupo.comision.trim(),
              practica: this.newGrupo.practica,
              integrantes: validIntegrantes.map(i => ({
                id: i.dbId,
                nombre: i.nombre.trim(),
                rol: i.rol.trim(),
                obs: i.observacion.trim()
              }))
            };
          }
          
        } else {
          // CREAR NUEVO GRUPO
          const nextId = Math.max(0, ...this.grupos.map(g => g.id)) + 1;
          
          const { data: grupoData, error: grupoError } = await supabase
            .from('grupos')
            .insert({
              id: nextId,
              proyecto: this.newGrupo.proyecto.trim(),
              comision: this.newGrupo.comision.trim(),
              practica: this.newGrupo.practica
            })
            .select()
            .single();
          
          if (grupoError) throw grupoError;
          
          for (const int of validIntegrantes) {
            const { error: intError } = await supabase
              .from('integrantes')
              .insert({
                grupo_id: nextId,
                nombre: int.nombre.trim(),
                rol: int.rol.trim(),
                observacion: int.observacion.trim()
              });
            if (intError) console.warn('Error insertando integrante:', intError);
          }
          
          this.grupos.push({
            id: nextId,
            proyecto: this.newGrupo.proyecto.trim(),
            comision: this.newGrupo.comision.trim(),
            practica: this.newGrupo.practica,
            integrantes: validIntegrantes.map(i => ({
              nombre: i.nombre.trim(),
              rol: i.rol.trim(),
              obs: i.observacion.trim()
            }))
          });
        }
        
        // Reset
        this.newGrupo = {
          proyecto: '',
          comision: '',
          practica: 'P2',
          integrantes: [{nombre:'',rol:'',observacion:'', dbId:null}]
        };
        this.editingGrupoId = null;
        this.showAddGrupo = false;
        
      } catch (e) {
        this.addGrupoError = e.message || 'Error al guardar grupo';
      } finally {
        this.loadingAddGrupo = false;
      }
    },
    
    confirmDeleteGrupo() {
      this.grupoToDelete = this.grupoActual;
      this.showConfirmDelete = true;
    },
    
    async eliminarGrupoConfirmado() {
      if (!this.grupoToDelete || !this.canEdit) return;
      this.loadingDelete = true;
      
      try {
        const { error } = await supabase
          .from('grupos')
          .delete()
          .eq('id', this.grupoToDelete.id);
        
        if (error) throw error;
        
        this.grupos = this.grupos.filter(g => g.id !== this.grupoToDelete.id);
        
        ENCUENTROS_META.forEach(e => {
          if (this.data[e.id]) {
            delete this.data[e.id][this.grupoToDelete.id];
          }
        });
        
        this.showConfirmDelete = false;
        this.grupoToDelete = null;
        this.view = 'resumen';
        
      } catch (e) {
        alert('Error al eliminar: ' + e.message);
      } finally {
        this.loadingDelete = false;
      }
    },
    
    async guardarComision() {
      if (!this.canEdit) return;
      this.addComisionError = '';
      
      try {
        if (!this.newComision.id.trim() || !this.newComision.nombre.trim()) {
          throw new Error('Código y nombre son obligatorios');
        }
        
        const { data, error } = await supabase
          .from('comisiones')
          .insert({
            id: this.newComision.id.trim(),
            nombre: this.newComision.nombre.trim(),
            activa: true
          })
          .select()
          .single();
        
        if (error) throw error;
        
        this.comisiones.push(data);
        this.comisiones.sort((a, b) => a.nombre.localeCompare(b.nombre));
        
        this.newComision = { id: '', nombre: '' };
        this.showAddComision = false;
        
      } catch (e) {
        this.addComisionError = e.message || 'Error al crear comisión';
      }
    }
  }));

  Alpine.start();
</script>
